.custom-tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  pointer-events: none;
  opacity: 0;
  transform: translate3d(0, 8rpx, 0);
  transition:
    opacity 120ms ease,
    transform 160ms ease;
  will-change: opacity, transform;
}

.custom-tab-bar.is-ready {
  opacity: 1;
  transform: translate3d(0, 0, 0);
}

.custom-tab-bar__surface {
  margin: 0 30rpx calc(26rpx + env(safe-area-inset-bottom));
  pointer-events: auto;
}

.custom-tab-bar__track {
  display: flex;
  align-items: stretch;
  gap: 8rpx;
  padding: 10rpx;
  border-radius: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 14rpx 30rpx rgba(0, 95, 155, 0.1);
  backdrop-filter: blur(25px);
  -webkit-backdrop-filter: blur(25px);
  overflow: hidden;
  isolation: isolate;
  transform: translateZ(0);
  backface-visibility: hidden;
}

.tab-item {
  position: relative;
  flex: 1;
  min-height: 78rpx;
  border-radius: 22rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  color: #9a9d9f;
  overflow: hidden;
  pointer-events: auto;
  transition:
    color 180ms ease,
    transform 180ms ease;
}

.tab-item__active-bg {
  position: absolute;
  inset: 4rpx 11rpx;
  border-radius: 17rpx;
  background: linear-gradient(180deg, rgba(0, 191, 255, 0.14), rgba(0, 191, 255, 0.04));
  box-shadow:
    inset 0 0 0 1rpx rgba(0, 191, 255, 0.05),
    0 0 10rpx rgba(0, 191, 255, 0.09);
  opacity: 0;
  transform: scale(0.965);
  will-change: opacity, transform;
}

.tab-item__water-ripple {
  position: absolute;
  inset: 9rpx 13rpx;
  border-radius: 16rpx;
  background:
    radial-gradient(circle at 50% 38%, rgba(0, 191, 255, 0.2) 0%, rgba(0, 191, 255, 0.12) 34%, rgba(0, 191, 255, 0.05) 56%, rgba(0, 191, 255, 0) 76%);
  opacity: 0;
  transform: scale(0.8);
  filter: blur(1rpx);
}

.tab-item--active {
  color: #005f9b;
}

.tab-item--active .tab-item__active-bg {
  opacity: 1;
  transform: scale(1);
}

.tab-item--active .tab-item__water-ripple {
  opacity: 1;
  animation: tabWaterRipple 2.4s ease-in-out infinite;
}

.tab-item__icon-wrap {
  position: relative;
  z-index: 1;
  width: 34rpx;
  height: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition:
    transform 220ms ease,
    filter 220ms ease;
}

.tab-item--active .tab-item__icon-wrap {
  transform: translateY(-3rpx) scale(1.08);
  filter: drop-shadow(0 8rpx 12rpx rgba(0, 191, 255, 0.22));
}

.tab-item__icon {
  width: 34rpx;
  height: 34rpx;
  display: block;
}

.tab-item__text {
  position: relative;
  z-index: 1;
  font-size: 20rpx;
  line-height: 1.2;
  font-weight: 500;
  transition:
    color 180ms ease,
    transform 180ms ease;
}

.tab-item--active .tab-item__text {
  color: #005f9b;
  transform: translateY(-1rpx);
}

@keyframes tabWaterRipple {
  0%,
  100% {
    transform: scale(0.94);
    opacity: 0.72;
  }

  50% {
    transform: scale(1.06);
    opacity: 1;
  }
}
