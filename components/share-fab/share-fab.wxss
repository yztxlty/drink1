.share-fab-root {
  position: fixed;
  z-index: 9999;
  right: 20rpx;
  display: block;
  padding: 0 !important;
  margin: 0 !important;
  border: none !important;
  border-radius: 999rpx;
  overflow: visible;
  background: none !important;
  background-color: transparent !important;
  outline: none !important;
  color: inherit !important;
  appearance: none;
  -webkit-appearance: none;
  opacity: 0;
  transform: translate3d(0, 14rpx, 0);
  transition:
    opacity 220ms ease,
    transform 260ms cubic-bezier(0.2, 0.8, 0.2, 1),
    right 260ms cubic-bezier(0.2, 0.8, 0.2, 1),
    width 260ms cubic-bezier(0.2, 0.8, 0.2, 1),
    height 260ms cubic-bezier(0.2, 0.8, 0.2, 1);
}

.share-fab-root::after {
  border: none !important;
}

.share-fab-root.is-ready {
  opacity: 1;
  transform: translate3d(0, 0, 0);
}

.share-fab-root.is-expanded {
  right: 20rpx;
}

.share-fab-root.is-collapsed {
  right: 20rpx;
}

.share-fab-root.is-dragging {
  transition:
    opacity 120ms ease,
    transform 0ms linear,
    right 0ms linear,
    width 0ms linear,
    height 0ms linear;
}

.share-fab-shell {
  position: relative;
  width: 100%;
  height: 100%;
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  border-radius: inherit;
  overflow: hidden;
  background:
    radial-gradient(circle at 26% 24%, rgba(255, 255, 255, 0.62), transparent 22%),
    radial-gradient(circle at 78% 68%, rgba(255, 255, 255, 0.18), transparent 24%),
    linear-gradient(135deg, rgba(124, 229, 255, 0.94) 0%, rgba(30, 173, 255, 0.9) 48%, rgba(22, 117, 225, 0.92) 100%);
  box-shadow:
    0 18rpx 42rpx rgba(0, 78, 124, 0.24),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.38);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
}

.share-fab-ripple {
  position: absolute;
  inset: 0;
  border-radius: inherit;
  pointer-events: none;
}

.share-fab-ripple-a {
  background:
    radial-gradient(circle at 20% 24%, rgba(255, 255, 255, 0.24), transparent 20%),
    radial-gradient(circle at 72% 62%, rgba(255, 255, 255, 0.14), transparent 28%);
  animation: shareFabRippleA 3.6s ease-in-out infinite;
}

.share-fab-ripple-b {
  background:
    radial-gradient(circle at 42% 40%, rgba(255, 255, 255, 0.16), transparent 18%),
    radial-gradient(circle at 64% 72%, rgba(255, 255, 255, 0.1), transparent 24%);
  animation: shareFabRippleB 5s ease-in-out infinite;
}

.share-fab-sheen {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.22) 0%, rgba(255, 255, 255, 0.04) 32%, rgba(255, 255, 255, 0) 56%);
  mix-blend-mode: screen;
  pointer-events: none;
}

.share-fab-core {
  position: relative;
  z-index: 1;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  padding: 0 22rpx 0 20rpx;
}

.share-fab-root.is-collapsed .share-fab-core {
  justify-content: flex-start;
  padding-left: 20rpx;
  padding-right: 16rpx;
}

.share-fab-orb {
  position: absolute;
  inset: 14rpx;
  border-radius: inherit;
  background:
    radial-gradient(circle at 32% 28%, rgba(255, 255, 255, 0.64), transparent 26%),
    radial-gradient(circle at 65% 68%, rgba(255, 255, 255, 0.12), transparent 34%);
  box-shadow:
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.16),
    inset 0 -8rpx 18rpx rgba(16, 124, 202, 0.16);
  opacity: 0.78;
  pointer-events: none;
}

.share-fab-share-text {
  position: relative;
  z-index: 2;
  display: block;
  font-size: 30rpx;
  line-height: 1;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: 4rpx;
  white-space: nowrap;
  text-shadow: 0 2rpx 10rpx rgba(0, 43, 77, 0.3);
}

.share-fab-root.is-collapsed .share-fab-shell {
  box-shadow:
    0 14rpx 34rpx rgba(0, 78, 124, 0.18),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
}

.share-fab-root.is-collapsed .share-fab-share-text {
  transform: translate3d(0, 0, 0);
  margin-left: 4rpx;
}

.share-fab-root.is-pressed .share-fab-shell {
  transform: scale(0.98);
}

@keyframes shareFabRippleA {
  0%,
  100% {
    opacity: 0.84;
    transform: scale(1);
  }
  50% {
    opacity: 1;
    transform: scale(1.05);
  }
}

@keyframes shareFabRippleB {
  0%,
  100% {
    opacity: 0.62;
    transform: scale(1);
  }
  50% {
    opacity: 0.94;
    transform: scale(1.08);
  }
}
