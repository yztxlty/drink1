.glass-card {
  position: relative;
  overflow: hidden;
  padding: 36rpx 32rpx 32rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(28rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  box-shadow: 0 24rpx 60rpx rgba(0, 95, 155, 0.08);
  border-radius: 32rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 24rpx;
  gap: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
}

.section-note {
  display: block;
  margin-top: 8rpx;
  color: var(--on-surface-variant);
  font-size: 22rpx;
}

.chip-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}

.amount-chip {
  background: var(--surface-container-low, #eef3f7);
  color: var(--on-surface, #32363a);
  border-radius: 9999rpx;
  padding: 14rpx 24rpx;
  font-size: 24rpx;
}

.primary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #005f9b, #4ba9e9);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.quick-amount-manager {
  position: relative;
}

.quick-amount-count {
  flex: none;
  min-width: 88rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(0, 95, 155, 0.1);
  color: var(--primary);
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
}

.quick-amount-head-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: none;
}

.quick-amount-edit {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: rgba(0, 95, 155, 0.08);
}

.quick-amount-edit-action {
  width: 100%;
  height: 100%;
  color: var(--primary);
  font-size: 28rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.quick-amount-grid {
  align-items: flex-start;
}

.quick-amount-chip {
  position: relative;
  min-width: 144rpx;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-right: 56rpx;
  text-align: center;
  font-weight: 600;
}

.quick-amount-chip.selected {
  box-shadow: inset 0 0 0 2rpx rgba(0, 95, 155, 0.22);
  color: var(--primary);
}

.quick-amount-chip.delete-ready {
  background: rgba(255, 235, 238, 0.94);
  box-shadow: inset 0 0 0 2rpx rgba(229, 57, 53, 0.18);
}

.add-chip {
  gap: 8rpx;
  padding-right: 24rpx;
  background: linear-gradient(135deg, rgba(0, 95, 155, 0.12), rgba(71, 166, 247, 0.08));
  color: var(--primary);
}

.add-chip-action {
  width: 100%;
  min-height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.add-chip-plus {
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1;
}

.add-chip-label {
  font-size: 22rpx;
  font-weight: 700;
}

.quick-amount-value {
  display: block;
  font-size: 24rpx;
  line-height: 1.2;
}

.quick-amount-delete {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 34rpx;
  height: 34rpx;
  overflow: hidden;
  border-radius: 50%;
  background: #e53935;
  box-shadow: 0 8rpx 20rpx rgba(229, 57, 53, 0.24);
}

.quick-amount-delete-action {
  width: 100%;
  height: 100%;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.quick-amount-hint {
  display: block;
  margin-top: 18rpx;
}

.quick-amount-mask {
  position: fixed;
  inset: 0;
  z-index: 40;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 32rpx;
  background: rgba(15, 23, 42, 0.34);
}

.quick-amount-dialog {
  width: 100%;
  max-width: 640rpx;
  padding-top: 34rpx;
}

.quick-amount-dialog-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.quick-amount-close {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: rgba(223, 227, 230, 0.56);
  color: var(--on-surface-variant);
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.quick-amount-stepper {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 24rpx;
  padding: 18rpx;
  border-radius: 28rpx;
  background: rgba(247, 251, 255, 0.92);
}

.step-btn {
  width: 92rpx;
  height: 92rpx;
  border-radius: 26rpx;
  background: linear-gradient(135deg, rgba(0, 95, 155, 0.14), rgba(71, 166, 247, 0.1));
  color: var(--primary);
  font-size: 40rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.quick-amount-draft {
  flex: 1;
  text-align: center;
  font-size: 42rpx;
  font-weight: 800;
  color: var(--on-surface);
}

.quick-amount-dialog-tip {
  display: block;
  margin-top: 18rpx;
}

.quick-amount-confirm {
  width: 100% !important;
  margin-top: 22rpx;
}
