.page-status-strip {
  padding: 26rpx 26rpx 24rpx;
  border-radius: 34rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.94), rgba(245, 248, 250, 0.86));
  box-shadow: 0 18rpx 38rpx rgba(12, 53, 82, 0.08);
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.page-status-strip--home {
  background: linear-gradient(135deg, rgba(71, 166, 247, 0.18), rgba(255, 255, 255, 0.94));
}

.page-status-strip--normal {
  background: linear-gradient(135deg, rgba(71, 166, 247, 0.18), rgba(255, 255, 255, 0.94));
}

.page-status-strip--complete {
  background: linear-gradient(135deg, rgba(77, 182, 172, 0.18), rgba(255, 255, 255, 0.94));
}

.page-status-strip--overflow {
  background: linear-gradient(135deg, rgba(41, 98, 255, 0.18), rgba(255, 255, 255, 0.94));
}

.page-status-strip--severe_overflow {
  background: linear-gradient(135deg, rgba(244, 81, 30, 0.2), rgba(255, 255, 255, 0.94));
}

.page-status-strip--profile,
.page-status-strip--profile-manual {
  background: linear-gradient(135deg, rgba(126, 111, 255, 0.16), rgba(255, 255, 255, 0.94));
}

.page-status-strip--forest,
.page-status-strip--forest-complete {
  background: linear-gradient(135deg, rgba(91, 253, 140, 0.16), rgba(255, 255, 255, 0.94));
}

.page-status-strip__header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
}

.page-status-strip__copy {
  flex: 1;
  min-width: 0;
}

.page-status-strip__title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.2;
  color: var(--on-surface);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.page-status-strip__subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: var(--on-surface-variant);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.page-status-strip__action {
  min-width: 132rpx;
  height: 60rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: var(--primary);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 24rpx rgba(0, 95, 155, 0.16);
}

.page-status-strip__action.is-disabled {
  opacity: 0.45;
}

.page-status-strip__metric {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.page-status-strip__metric-value {
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1;
  color: var(--primary);
  white-space: nowrap;
}

.page-status-strip__metric-label {
  font-size: 22rpx;
  color: var(--on-surface-variant);
  white-space: nowrap;
}
