.contact-dialog-root {
  position: fixed;
  inset: 0;
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 220ms ease;
}

.contact-dialog-root.is-visible {
  opacity: 1;
  pointer-events: auto;
}

.contact-dialog-mask {
  position: absolute;
  inset: 0;
  background: rgba(10, 35, 20, 0.45);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.contact-dialog-card {
  position: relative;
  z-index: 1;
  width: 640rpx;
  max-width: 86vw;
  padding: 42rpx 34rpx 36rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: 0 26rpx 70rpx rgba(0, 88, 42, 0.2);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.contact-dialog-header {
  width: 100%;
  text-align: center;
}

.contact-dialog-title {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: #153a27;
  line-height: 1.25;
}

.contact-dialog-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: rgba(21, 58, 39, 0.72);
  line-height: 1.5;
}

.contact-dialog-qr-wrap {
  width: 416rpx;
  height: 416rpx;
  margin-top: 28rpx;
  padding: 18rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(7, 193, 96, 0.16);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.5);
}

.contact-dialog-qr {
  width: 100%;
  height: 100%;
  border-radius: 22rpx;
  background: rgba(247, 251, 248, 0.95);
}

.contact-dialog-tip {
  margin-top: 24rpx;
  font-size: 22rpx;
  line-height: 1.6;
  text-align: center;
  color: rgba(21, 58, 39, 0.76);
}

.contact-dialog-save-btn {
  width: 100%;
  margin-top: 30rpx;
  height: 90rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  border: none;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  background: rgba(7, 193, 96, 0.8);
  box-shadow: 0 16rpx 36rpx rgba(7, 193, 96, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
}

.contact-dialog-save-btn::after {
  border: none;
}

.contact-dialog-save-btn[disabled] {
  opacity: 0.76;
  box-shadow: 0 10rpx 22rpx rgba(7, 193, 96, 0.18);
}
