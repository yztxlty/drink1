/* pages/profile/profile.wxss */
.profile-page {
  gap: 24rpx;
  padding-bottom: 60rpx;
}

.profile-hero {
  position: relative;
  padding: 42rpx 32rpx 36rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero-watermark {
  position: absolute;
  top: -50rpx;
  right: -30rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(0, 241, 253, 0.18), transparent 70%);
  pointer-events: none;
}

.avatar-group {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  z-index: 1;
}

.avatar-lg {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  overflow: hidden;
  border: 8rpx solid rgba(255, 255, 255, 0.94);
  box-shadow: 0 20rpx 40rpx rgba(16, 53, 83, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(234, 245, 252, 0.72));
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.avatar-fallback {
  font-size: 60rpx;
  font-weight: 800;
  color: var(--primary);
}

.edit-btn {
  position: absolute;
  right: -8rpx;
  bottom: 12rpx;
  min-width: 92rpx;
  height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--primary), var(--primary-container));
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 24rpx rgba(0, 95, 155, 0.18);
}

.profile-meta {
  margin-top: 28rpx;
  text-align: center;
  z-index: 1;
}

.display-name {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.2;
}

.badge-role {
  display: inline-block;
  margin-top: 14rpx;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(71, 166, 247, 0.12);
  color: var(--primary);
  font-size: 22rpx;
  font-weight: 700;
}

.profile-desc {
  display: block;
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--on-surface-variant);
}

.profile-chip-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 14rpx;
  margin-top: 28rpx;
  z-index: 1;
}

.profile-chip {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.54);
  color: var(--on-surface);
  font-size: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
}

.stats-row {
  padding: 34rpx 10rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.stat-unit {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.val {
  font-size: 42rpx;
  font-weight: 800;
  color: var(--on-surface);
}

.unit {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--on-surface-variant);
}

.stat-divider {
  width: 2rpx;
  height: 64rpx;
  background: linear-gradient(180deg, rgba(223, 227, 230, 0), rgba(223, 227, 230, 1), rgba(223, 227, 230, 0));
}

.analysis-card,
.badge-preview,
.export-card {
  padding-top: 36rpx;
}

.record-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
}

.section-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--on-surface-variant);
  line-height: 1.5;
}

.analysis-tag,
.inline-link {
  flex: none;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(0, 95, 155, 0.1);
  color: var(--primary);
  font-size: 22rpx;
  font-weight: 700;
}

.inline-link {
  margin-top: 4rpx;
}

.analysis-grid {
  display: flex;
  gap: 18rpx;
  margin-top: 26rpx;
}

.analysis-period-tabs {
  display: flex;
  gap: 14rpx;
  margin-top: 24rpx;
}

.analysis-period-tab {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: var(--on-surface-variant);
  background: rgba(255, 255, 255, 0.56);
}

.analysis-period-tab.active {
  background: linear-gradient(135deg, rgba(0, 95, 155, 0.9), rgba(67, 168, 236, 0.92));
  color: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(0, 95, 155, 0.24);
}

.analysis-chart-wrap {
  margin-top: 20rpx;
  padding: 22rpx 18rpx 18rpx;
  border-radius: 28rpx;
  background: radial-gradient(circle at 20% 12%, rgba(255, 255, 255, 0.7), rgba(223, 240, 251, 0.52));
  border: 1rpx solid rgba(255, 255, 255, 0.72);
}

.analysis-chart-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.analysis-chart-title {
  font-size: 24rpx;
  font-weight: 700;
}

.analysis-chart-meta {
  font-size: 20rpx;
  color: var(--primary);
}

.analysis-chart {
  position: relative;
  height: 280rpx;
  margin-top: 18rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.62), rgba(215, 238, 253, 0.42));
}

.analysis-chart-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(to top, rgba(0, 95, 155, 0.06) 1rpx, transparent 1rpx),
    linear-gradient(to right, rgba(0, 95, 155, 0.05) 1rpx, transparent 1rpx);
  background-size: 100% 25%, 12.5% 100%;
}

.analysis-target-line {
  position: absolute;
  left: 0;
  right: 0;
  height: 0;
  border-top: 2rpx dashed rgba(0, 95, 155, 0.78);
  z-index: 4;
}

.analysis-target-label {
  position: absolute;
  right: 6rpx;
  top: -30rpx;
  font-size: 18rpx;
  color: var(--primary);
  background: rgba(255, 255, 255, 0.74);
  border-radius: 999rpx;
  padding: 4rpx 10rpx;
}

.analysis-line-layer {
  position: absolute;
  inset: 0;
  z-index: 5;
  pointer-events: none;
}

.analysis-line-segment {
  position: absolute;
  height: 4rpx;
  transform-origin: left center;
  background: linear-gradient(90deg, rgba(0, 95, 155, 0.86), rgba(76, 198, 249, 0.92));
  box-shadow: 0 0 10rpx rgba(0, 95, 155, 0.24);
  animation: lineGlow 2.6s ease-in-out infinite;
}

.analysis-line-point {
  position: absolute;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #ffffff;
  border: 3rpx solid rgba(0, 95, 155, 0.9);
  box-shadow: 0 0 18rpx rgba(0, 95, 155, 0.36);
}

.analysis-bars-layer {
  position: absolute;
  inset: 0;
  z-index: 3;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 18rpx 8rpx 12rpx;
  box-sizing: border-box;
}

.analysis-bar-item {
  flex: 1;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
  gap: 6rpx;
}

.analysis-bar-amount {
  font-size: 18rpx;
  color: rgba(16, 53, 83, 0.7);
}

.analysis-bar-shell {
  width: 62%;
  height: 72%;
  display: flex;
  align-items: flex-end;
}

.analysis-bar-crystal {
  width: 100%;
  min-height: 12rpx;
  border-radius: 18rpx 18rpx 8rpx 8rpx;
  background: linear-gradient(180deg, rgba(169, 231, 255, 0.95) 0%, rgba(85, 173, 239, 0.92) 50%, rgba(0, 95, 155, 0.9) 100%);
  box-shadow: inset -6rpx 0 8rpx rgba(255, 255, 255, 0.34), inset 6rpx 0 10rpx rgba(0, 53, 93, 0.16), 0 8rpx 14rpx rgba(0, 95, 155, 0.2);
  animation: crystalPulse 2.8s ease-in-out infinite;
}

.analysis-bar-label {
  font-size: 18rpx;
  color: var(--on-surface-variant);
}

.analysis-item {
  flex: 1;
  padding: 24rpx 18rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.52);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 12rpx 24rpx rgba(16, 53, 83, 0.05);
}

.analysis-value {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--primary);
}

.analysis-label {
  font-size: 22rpx;
  color: var(--on-surface-variant);
}

.analysis-summary,
.analysis-suggestion {
  display: block;
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--on-surface);
}

.analysis-suggestion {
  color: var(--on-surface-variant);
}

.badge-scroll-view {
  width: 100%;
  margin-top: 24rpx;
  position: relative;
  -webkit-mask-image: linear-gradient(to right, black 86%, transparent 100%);
  mask-image: linear-gradient(to right, black 86%, transparent 100%);
}

.badge-list {
  display: flex !important;
  flex-direction: row !important;
  gap: 20rpx;
  padding: 8rpx 10rpx 24rpx 2rpx;
}

.badge-card {
  flex: 0 0 164rpx;
  min-height: 196rpx;
  padding: 24rpx 16rpx;
  border-radius: 36rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(240, 247, 252, 0.88));
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  border: 1.5rpx solid rgba(255, 255, 255, 0.7);
  box-shadow: 0 14rpx 34rpx rgba(16, 53, 83, 0.07);
}

.badge-art {
  position: relative;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 50% 35%, rgba(255, 255, 255, 0.98), rgba(231, 245, 255, 0.78) 60%, rgba(0, 95, 155, 0.1) 100%);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.9), 0 12rpx 24rpx rgba(16, 53, 83, 0.08);
  overflow: hidden;
}

.badge-halo {
  position: absolute;
  inset: -16rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(0, 95, 155, 0.15), transparent 68%);
  filter: blur(8rpx);
}

.badge-icon-img {
  position: relative;
  z-index: 1;
  width: 100%;
  height: 100%;
  padding: 16rpx;
  box-sizing: border-box;
  filter: drop-shadow(0 10rpx 16rpx rgba(13, 45, 74, 0.18));
}

.badge-card.locked {
  opacity: 0.96;
  transform: scale(1);
  border-color: rgba(94, 183, 237, 0.62);
}

.badge-name {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--on-surface);
  text-align: center;
  line-height: 1.2;
}

.badge-progress {
  font-size: 20rpx;
  color: var(--on-surface-variant);
}

@keyframes crystalPulse {
  0% {
    filter: brightness(1) saturate(1);
  }
  50% {
    filter: brightness(1.08) saturate(1.1);
  }
  100% {
    filter: brightness(1) saturate(1);
  }
}

@keyframes lineGlow {
  0% {
    opacity: 0.68;
    box-shadow: 0 0 6rpx rgba(0, 95, 155, 0.16);
  }
  50% {
    opacity: 1;
    box-shadow: 0 0 14rpx rgba(0, 95, 155, 0.36);
  }
  100% {
    opacity: 0.68;
    box-shadow: 0 0 6rpx rgba(0, 95, 155, 0.16);
  }
}

.export-hint-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 24rpx;
}

.export-hint-chip {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.52);
  font-size: 22rpx;
  color: var(--on-surface-variant);
}

.export-result {
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.56);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.export-result-title {
  font-size: 22rpx;
  color: var(--primary);
  font-weight: 700;
}

.export-result-file {
  font-size: 26rpx;
  font-weight: 700;
}

.export-result-path {
  font-size: 22rpx;
  color: var(--on-surface-variant);
  word-break: break-all;
  line-height: 1.6;
}

.sync-btn {
  width: 100% !important;
  margin-top: 22rpx;
}

.menu-group {
  overflow: hidden;
  padding: 12rpx 0 0;
}

.menu-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 34rpx;
  border-bottom: 1rpx solid rgba(223, 227, 230, 0.72);
}

.menu-line.last {
  border-bottom: none;
}

.menu-texts {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.lab {
  font-size: 30rpx;
  font-weight: 700;
}

.sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--on-surface-variant);
  line-height: 1.6;
}

.menu-side {
  display: flex;
  align-items: center;
}

.arr {
  font-size: 24rpx;
  color: rgba(89, 92, 94, 0.5);
}

.notif-dot {
  width: 12rpx;
  height: 12rpx;
  margin-right: 18rpx;
  border-radius: 50%;
  background: var(--danger);
}

.actions-footer {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  padding-bottom: 10rpx;
}

.logout-text {
  text-align: center;
  color: var(--danger);
  font-size: 28rpx;
  font-weight: 700;
}
