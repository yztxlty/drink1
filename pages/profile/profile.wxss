/* pages/profile/profile.wxss */
.profile-page {
  gap: 24rpx;
  padding-bottom: 60rpx;
}

.profile-hero {
  padding-top: 46rpx;
  padding-bottom: 42rpx;
}

.hero-watermark {
  position: absolute;
  top: -40rpx;
  right: -20rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(0, 241, 253, 0.18), transparent 70%);
}

.user-info-section {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-group {
  position: relative;
  width: 196rpx;
  height: 196rpx;
}

.avatar-lg {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  overflow: hidden;
  border: 8rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 20rpx 40rpx rgba(16, 53, 83, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.avatar-fallback {
  font-size: 60rpx;
  font-weight: 800;
  color: var(--primary);
}

.edit-btn {
  position: absolute;
  right: -6rpx;
  bottom: 12rpx;
  min-width: 92rpx;
  height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--primary), var(--primary-container));
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
}

.profile-meta {
  margin-top: 28rpx;
  text-align: center;
}

.display-name {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.2;
}

.badge-role {
  display: inline-block;
  margin-top: 14rpx;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(71, 166, 247, 0.12);
  color: var(--primary);
  font-size: 22rpx;
  font-weight: 700;
}

.profile-desc {
  display: block;
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--on-surface-variant);
}

.stats-row {
  padding: 34rpx 10rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.stat-unit {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.val {
  font-size: 42rpx;
  font-weight: 800;
  color: var(--on-surface);
}

.unit {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--on-surface-variant);
}

.stat-divider {
  width: 2rpx;
  height: 64rpx;
  background: linear-gradient(180deg, rgba(223, 227, 230, 0), rgba(223, 227, 230, 1), rgba(223, 227, 230, 0));
}

.badge-preview {
  padding-top: 36rpx;
}

.record-head {
  display: flex;
  justify-content: space-between;
}

.badge-scroll-view {
  width: 100%;
  margin-top: 24rpx;
  position: relative;
  mask-image: linear-gradient(to right, black 85%, transparent 100%);
  -webkit-mask-image: linear-gradient(to right, black 85%, transparent 100%);
}

.badge-list {
  display: flex !important; /* Force flex-row */
  flex-direction: row !important;
  padding: 0 30rpx 40rpx;
  gap: 20rpx;
}

.badge-card {
  flex: 0 0 162rpx; /* Fixed width to prevent squashing */
  min-height: 172rpx;
  padding: 28rpx 12rpx;
  border-radius: 38rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(238, 241, 243, 0.92));
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.badge-icon-img {
  width: 88rpx;
  height: 88rpx;
  filter: drop-shadow(0 4rpx 12rpx rgba(0, 0, 0, 0.08));
}

.badge-card.locked {
  filter: grayscale(100%);
  opacity: 0.45;
  transform: scale(0.96);
}

.badge-name {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--on-surface);
  text-align: center;
  line-height: 1.2;
  white-space: nowrap; /* Prevent vertical text */
  letter-spacing: 0.5rpx;
}

.menu-group {
  overflow: hidden;
  padding: 12rpx 0 0;
}

.menu-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 34rpx;
  border-bottom: 1rpx solid rgba(223, 227, 230, 0.72);
}

.menu-line.last {
  border-bottom: none;
}

.menu-texts {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.lab {
  font-size: 30rpx;
  font-weight: 700;
}

.sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--on-surface-variant);
  line-height: 1.6;
}

.menu-side {
  display: flex;
  align-items: center;
}

.arr {
  font-size: 24rpx;
  color: rgba(89, 92, 94, 0.5);
}

.notif-dot {
  width: 12rpx;
  height: 12rpx;
  margin-right: 18rpx;
  border-radius: 50%;
  background: var(--danger);
}

.actions-footer {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.sync-btn {
  width: 100% !important;
}

.logout-text {
  text-align: center;
  color: var(--danger);
  font-size: 28rpx;
  font-weight: 700;
}
