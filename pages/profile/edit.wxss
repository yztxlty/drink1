/* pages/profile/edit.wxss */
.edit-page {
  gap: 24rpx;
  padding-bottom: 60rpx;
}

.editor-card {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.avatar-editor {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 22rpx;
}

.avatar-preview {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 18rpx 36rpx rgba(16, 53, 83, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.avatar-fallback {
  font-size: 58rpx;
  font-weight: 800;
  color: var(--primary);
}

.avatar-actions {
  display: flex;
  gap: 16rpx;
  width: 100%;
}

.mini-btn {
  flex: 1;
  min-height: 88rpx;
  font-size: 26rpx;
}

.field-group {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.field-label {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--on-surface);
}

.text-input,
.text-area {
  width: 100%;
  padding: 24rpx 28rpx;
  border-radius: var(--radius-lg);
  border: 2rpx solid rgba(223, 227, 230, 0.9);
  background: rgba(255, 255, 255, 0.92);
  color: var(--on-surface);
  font-size: 28rpx;
}

.text-area {
  min-height: 160rpx;
}

.hint-text {
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--on-surface-variant);
}

.action-row {
  display: flex;
  gap: 18rpx;
}

.action-btn {
  flex: 1;
}
