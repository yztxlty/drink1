<!-- pages/profile/profile.wxml -->
<scroll-view class="scrollarea" scroll-y>
  <view class="container profile-page">
    <page-status-strip
      tone="{{statusBar.tone}}"
      title="{{statusBar.title}}"
      subtitle="{{statusBar.subtitle}}"
      metricValue="{{statusBar.metricValue}}"
      metricLabel="{{statusBar.metricLabel}}"
      actionLabel="{{statusBar.actionLabel}}"
      bindaction="syncData"
    />

    <view class="profile-hero glass-card">
      <view class="hero-watermark"></view>
      <view class="avatar-group">
        <view class="avatar-lg">
          <image wx:if="{{profile.avatarUrl}}" class="avatar-image" src="{{profile.avatarUrl}}" mode="aspectFill" />
          <text wx:else class="avatar-fallback">{{profileInitial}}</text>
        </view>
        <view class="edit-btn" bindtap="goEditProfile">编辑</view>
      </view>

      <view class="profile-meta">
        <text class="display-name">{{profile.displayNickName || profile.nickName}}</text>
        <text class="badge-role">{{profile.isLoggedIn ? '微信授权档案' : '本地档案'}}</text>
        <text class="profile-desc">{{profile.motto}}</text>
      </view>

      <view class="profile-chip-row">
        <view class="profile-chip">目标 {{settings.dailyTarget}}ml</view>
        <view class="profile-chip">单次 {{settings.selectedCupAmount}}ml</view>
        <view class="profile-chip">{{summary.streakDays}} 天连续</view>
      </view>
    </view>

    <view class="stats-row glass-card">
      <view class="stat-unit">
        <text class="val">{{summary.streakDays}}</text>
        <text class="unit">连续天数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-unit">
        <text class="val">{{summary.totalLiters}}</text>
        <text class="unit">累计补水(L)</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-unit">
        <text class="val">{{analysis.recentCompletion}}</text>
        <text class="unit">近 7 天达标</text>
      </view>
    </view>

    <view class="analysis-card glass-card">
      <view class="record-head">
        <view>
          <text class="section-title">补水分析</text>
          <text class="section-subtitle">近 7 天表现与长期趋势</text>
        </view>
        <view class="analysis-tag">{{analysis.dominantPeriod}}时段更活跃</view>
      </view>

      <view class="analysis-grid">
        <view class="analysis-item">
          <text class="analysis-value">{{analysis.averageDaily}}</text>
          <text class="analysis-label">平均日补水</text>
        </view>
        <view class="analysis-item">
          <text class="analysis-value">{{analysis.averageCup}}</text>
          <text class="analysis-label">平均单次</text>
        </view>
        <view class="analysis-item">
          <text class="analysis-value">{{analysis.recentTotal}}</text>
          <text class="analysis-label">近 7 天总量</text>
        </view>
      </view>

      <text class="analysis-summary">{{analysis.summary}}</text>
      <text class="analysis-suggestion">{{analysis.suggestion}}</text>
    </view>

    <view class="badge-preview glass-card">
      <view class="record-head">
        <view>
          <text class="section-title">勋章橱窗</text>
          <text class="section-subtitle">系统勋章与成长进度预览</text>
        </view>
        <text class="inline-link" bindtap="goToMedals">查看全部</text>
      </view>

      <scroll-view
        class="badge-scroll-view"
        scroll-x
        enable-flex
        scroll-with-animation
        show-scrollbar="{{false}}"
      >
        <view class="badge-list">
          <view
            class="badge-card {{item.unlocked ? 'unlocked' : 'locked'}}"
            wx:for="{{badges}}"
            wx:key="id"
            bindtap="goToMedals"
          >
            <view class="badge-art">
              <view class="badge-halo"></view>
              <image class="badge-icon-img" src="{{item.icon}}" mode="aspectFit" />
            </view>
            <text class="badge-name">{{item.name}}</text>
            <text class="badge-progress">{{item.progressText}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="export-card glass-card">
      <view class="record-head">
        <view>
          <text class="section-title">同步补水资料</text>
          <text class="section-subtitle">导出标准 JSON 到本机存储</text>
        </view>
      </view>

      <view class="export-hint-row">
        <view class="export-hint-chip">标准 JSON</view>
        <view class="export-hint-chip">本机路径</view>
        <view class="export-hint-chip">用户自管</view>
      </view>

      <view wx:if="{{exportResult}}" class="export-result">
        <text class="export-result-title">最近导出</text>
        <text class="export-result-file">{{exportResult.filename}}</text>
        <text class="export-result-path">{{exportResult.path}}</text>
      </view>

      <button class="primary-btn sync-btn" bindtap="syncData">{{copy.actionLabel}}</button>
    </view>

    <view class="menu-group glass-card">
      <view
        class="menu-line {{index === menuItems.length - 1 ? 'last' : ''}}"
        wx:for="{{menuItems}}"
        wx:for-item="item"
        wx:for-index="index"
        wx:key="key"
        bindtap="navigateToMenu"
        data-key="{{item.key}}"
      >
        <view class="menu-texts">
          <text class="lab">{{item.title}}</text>
          <text class="sub">{{item.subtitle}}</text>
        </view>
        <view class="menu-side">
          <view wx:if="{{item.badge}}" class="notif-dot"></view>
          <text class="arr">></text>
        </view>
      </view>
    </view>

    <view class="actions-footer">
      <view class="logout-text" bindtap="logout">退出登录</view>
    </view>
  </view>
</scroll-view>
