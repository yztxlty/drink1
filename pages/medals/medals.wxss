/* pages/medals/medals.wxss */
.container {
  padding: 80rpx 40rpx 160rpx;
  background: var(--surface);
  min-height: 100vh;
}

.medal-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.hero-card {
  margin-bottom: 8rpx;
}

.hero-kicker {
  display: block;
  font-size: 22rpx;
  color: var(--primary);
  font-weight: 700;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.hero-title {
  display: block;
  font-size: 40rpx;
  line-height: 1.35;
  font-weight: 800;
  margin-top: 16rpx;
}

.hero-chip-row,
.tab-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}

.hero-chip,
.tab-item {
  border-radius: 9999rpx;
  font-size: 24rpx;
}

.hero-chip {
  background: var(--surface-container-low);
  color: var(--on-surface);
  padding: 14rpx 24rpx;
}

.tab-item {
  padding: 14rpx 24rpx;
  background: var(--surface-container-low);
  color: var(--on-surface-variant);
}

.tab-item.active {
  background: rgba(0, 95, 155, 0.1);
  color: var(--primary);
  font-weight: 700;
}

.medal-focus {
  display: flex;
  gap: 24rpx;
  align-items: center;
  padding: 30rpx 28rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, rgba(0, 95, 155, 0.05), rgba(0, 241, 253, 0.035));
  box-shadow: 0 18rpx 40rpx rgba(16, 53, 83, 0.08);
}

.focus-art {
  position: relative;
  width: 176rpx;
  height: 176rpx;
  flex: none;
  border-radius: 50%;
  background: transparent;
}

.focus-halo {
  position: absolute;
  inset: -10rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(57, 199, 255, 0.22), rgba(0, 95, 155, 0.06) 56%, transparent 70%);
  filter: blur(5rpx);
}

.focus-icon {
  position: relative;
  z-index: 1;
  width: 100%;
  height: 100%;
  padding: 8rpx;
  box-sizing: border-box;
  filter: drop-shadow(0 14rpx 24rpx rgba(13, 45, 74, 0.24)) saturate(1.32) brightness(1.1);
}

.focus-copy {
  flex: 1;
  min-width: 0;
}

.focus-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.focus-title {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
}

.focus-desc,
.focus-condition,
.focus-progress-text {
  display: block;
  font-size: 22rpx;
  color: var(--on-surface-variant);
  line-height: 1.6;
}

.focus-status {
  flex: none;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.focus-status.unlocked {
  background: rgba(15, 157, 88, 0.12);
  color: #0f9d58;
}

.focus-status.locked {
  background: rgba(0, 95, 155, 0.1);
  color: var(--primary);
}

.focus-condition {
  margin-top: 12rpx;
}

.focus-progress {
  margin-top: 18rpx;
}

.focus-track {
  width: 100%;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(223, 227, 230, 0.72);
  overflow: hidden;
}

.focus-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(0, 95, 155, 0.4), rgba(0, 95, 155, 0.96));
}

.focus-progress-text {
  margin-top: 10rpx;
}

.medal-gallery {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.medal-card {
  padding: 26rpx 22rpx;
  border-radius: 36rpx;
  overflow: hidden;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}

.medal-card.selected {
  box-shadow: 0 18rpx 42rpx rgba(16, 53, 83, 0.12);
  transform: translateY(-2rpx);
}

.medal-art {
  position: relative;
  width: 148rpx;
  height: 148rpx;
  border-radius: 50%;
  background: transparent;
  overflow: visible;
}

.medal-halo {
  position: absolute;
  inset: -9rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(57, 199, 255, 0.2), rgba(0, 95, 155, 0.05) 56%, transparent 70%);
  filter: blur(4rpx);
}

.medal-icon-img {
  position: relative;
  z-index: 1;
  width: 100%;
  height: 100%;
  padding: 8rpx;
  box-sizing: border-box;
  filter: drop-shadow(0 12rpx 22rpx rgba(13, 45, 74, 0.24)) saturate(1.3) brightness(1.1);
}

.medal-card.locked {
  opacity: 1;
  border-color: rgba(35, 178, 243, 0.72);
  box-shadow: 0 14rpx 32rpx rgba(16, 53, 83, 0.12);
}

.medal-copy {
  width: 100%;
  text-align: center;
}

.medal-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--on-surface);
}

.medal-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 20rpx;
  color: var(--primary);
}

.medal-condition {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: var(--on-surface-variant);
  line-height: 1.5;
}
