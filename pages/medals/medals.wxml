<!-- pages/medals/medals.wxml -->
<scroll-view class="scrollarea" scroll-y>
  <view class="container medal-page">
    <view class="hero-card glass-card">
      <text class="hero-kicker">{{copy.heroKicker}}</text>
      <text class="hero-title">{{copy.heroTitle}}</text>
      <view class="hero-chip-row">
        <view class="hero-chip">已解锁 {{summary.unlockedCount}}</view>
        <view class="hero-chip">总计 {{summary.totalCount}}</view>
        <view class="hero-chip">完成率 {{summary.completionRate}}</view>
      </view>
    </view>

    <view class="medal-focus glass-card" wx:if="{{selectedMedal}}">
      <view class="focus-art">
        <view class="focus-halo"></view>
        <image class="focus-icon" src="{{selectedMedal.icon}}" mode="aspectFit" />
      </view>
      <view class="focus-copy">
        <view class="focus-head">
          <view>
            <text class="focus-title">{{selectedMedal.title}}</text>
            <text class="focus-desc">{{selectedMedal.desc}}</text>
          </view>
          <text class="focus-status {{selectedMedal.unlocked ? 'unlocked' : 'locked'}}">{{selectedMedal.accentLabel}}</text>
        </view>
        <text class="focus-condition">解锁条件：{{selectedMedal.condition}}</text>
        <view class="focus-progress">
          <view class="focus-track">
            <view class="focus-fill" style="width: {{selectedMedal.progressPercent}}%;"></view>
          </view>
          <text class="focus-progress-text">{{selectedMedal.progressText}}</text>
        </view>
      </view>
    </view>

    <view class="tab-row">
      <view
        class="tab-item {{activeTab === item.key ? 'active' : ''}}"
        wx:for="{{tabs}}"
        wx:key="key"
        data-key="{{item.key}}"
        bindtap="switchTab"
      >
        {{item.label}}
      </view>
    </view>

    <view class="medal-gallery">
      <view
        class="medal-card glass-card {{item.unlocked ? 'unlocked' : 'locked'}} {{selectedMedal && selectedMedal.id === item.id ? 'selected' : ''}}"
        wx:for="{{visibleMedals}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="viewMedal"
      >
        <view class="medal-art">
          <view class="medal-halo"></view>
          <image class="medal-icon-img" src="{{item.icon}}" mode="aspectFit" />
        </view>
        <view class="medal-copy">
          <text class="medal-title">{{item.title}}</text>
          <text class="medal-desc">{{item.progressText}}</text>
          <text class="medal-condition">{{item.condition}}</text>
        </view>
      </view>
    </view>
  </view>
</scroll-view>
