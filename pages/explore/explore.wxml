<!-- pages/explore/explore.wxml -->
<scroll-view class="scrollarea" scroll-y>
  <view class="container forest-page">
    <page-status-strip
      tone="{{statusBar.tone}}"
      title="{{statusBar.title}}"
      subtitle="{{statusBar.subtitle}}"
      metricValue="{{statusBar.metricValue}}"
      metricLabel="{{statusBar.metricLabel}}"
      actionLabel=""
      bindaction="navHome"
    />

    <view class="forest-summary soft-panel">
      <view class="summary-rules-trigger" bindtap="showSummaryRules">{{summaryRulesTrigger}}</view>
      <view class="oxygen-info">
        <view class="oxygen-icon">O2</view>
        <view class="oxygen-meta">
          <text class="oxygen-value">{{oxygenValue}}</text>
          <text class="oxygen-label">森林氧气浓度</text>
        </view>
      </view>
      <view class="summary-stack">
        <view class="summary-pill summary-pill-primary">{{collectionLabel}}</view>
        <text class="summary-caption">融合进度</text>
      </view>
      <view class="summary-stack">
        <view class="summary-pill summary-pill-success">{{dropCount}} 颗</view>
        <text class="summary-caption">治愈水滴</text>
      </view>
    </view>

    <view class="forest-stage">
      <view class="stage-glow"></view>
      <view class="grid-bg"></view>

      <view class="stage-head">
        <view>
          <text class="section-title">{{gameCopy.gameTitle}}</text>
          <text class="section-subtitle">{{gameCopy.gameSubtitle}}</text>
        </view>
        <view class="stage-chip">Lv.{{forestLevel}}</view>
      </view>

      <view class="energy-status">{{intakeEnergyLabel}}</view>

      <view class="vessel-container">
        <view class="vessel-glow vessel-glow-top"></view>
        <view class="vessel-glow vessel-glow-bottom"></view>
        <view class="vessel-mist"></view>

        <block wx:if="{{drops.length}}">
          <block wx:for="{{drops}}" wx:key="id">
            <view
              class="water-drop {{item.isMerging ? 'merging' : ''}} {{item.isDragging ? 'dragging' : ''}}"
              style="left:{{item.x}}px; top:{{item.y}}px; width:{{item.size}}px; height:{{item.size}}px; background:{{item.color}};"
              data-id="{{item.id}}"
              catchtouchstart="touchStart"
              catchtouchmove="touchMove"
              catchtouchend="touchEnd"
              catchtouchcancel="touchEnd"
            >
              <view class="highlight"></view>
              <view class="drop-core"></view>
            </view>
          </block>
        </block>

        <view wx:else class="vessel-empty">{{gameCopy.emptyHint}}</view>
      </view>

      <view class="stage-caption">{{forestStatusHint}}</view>
    </view>

    <view class="achievement-overview glass-card">
      <view class="overview-head">
        <view>
          <text class="section-title">{{gameCopy.rulesTitle}}</text>
          <text class="section-subtitle">{{reminderText}}</text>
        </view>
      </view>

      <view class="forest-metrics">
        <view class="metric-block">
          <text class="metric-value">{{todayTotal}} ml</text>
          <text class="metric-label">今日已收集</text>
        </view>
        <view class="metric-block">
          <text class="metric-value">{{todayRemaining}} ml</text>
          <text class="metric-label">距离目标</text>
        </view>
        <view class="metric-block">
          <text class="metric-value">{{unlockedMedalCount}}</text>
          <text class="metric-label">已解锁勋章</text>
        </view>
      </view>
    </view>

    <view class="forest-log glass-card">
      <view class="overview-head">
        <view>
          <text class="section-title">今日守护</text>
          <text class="section-subtitle">每 50ml 会生成一颗初始水滴，拖动后可在容器内融合成长</text>
        </view>
      </view>

      <view class="forest-status-card">
        <view class="forest-row">
          <text class="forest-row-label">融合规则</text>
          <text class="forest-row-value forest-row-value-compact">当两个水滴中心距离小于半径之和时，会自动吞噬并放大</text>
        </view>
        <view class="forest-row">
          <text class="forest-row-label">交互反馈</text>
          <text class="forest-row-value forest-row-value-compact">融合时触发震动与清脆 pop 音效，营造 Q 弹反馈</text>
        </view>
        <view class="forest-row">
          <text class="forest-row-label">继续补水</text>
          <text class="forest-row-value forest-row-value-compact">想要更多水滴，就先回首页再记录新的补水量</text>
        </view>
      </view>

      <button class="primary-btn forest-action-btn" bindtap="navHome">{{statusBar.actionLabel}}</button>
    </view>

    <view class="bottom-space"></view>
  </view>
</scroll-view>

<share-fab id="shareFab" page-name="explore" percent="{{shareProgressPercent}}" streak="{{shareStreakDays}}" />
