/* pages/explore/explore.wxss */
.forest-page {
  gap: 24rpx;
  padding-bottom: 84rpx;
}

.forest-summary,
.overview-head,
.forest-metrics,
.forest-status-card,
.forest-row,
.stage-head {
  display: flex;
}

.forest-summary {
  position: relative;
  justify-content: space-between;
  align-items: center;
  padding: 68rpx 28rpx 24rpx;
}

.summary-rules-trigger {
  position: absolute;
  top: 22rpx;
  right: 24rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.88);
  color: var(--primary);
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1;
  box-shadow: 0 10rpx 20rpx rgba(0, 95, 155, 0.08);
}

.oxygen-info {
  display: flex;
  align-items: center;
}

.oxygen-icon {
  width: 92rpx;
  height: 92rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, var(--primary), var(--primary-container));
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
  box-shadow: 0 16rpx 30rpx rgba(0, 95, 155, 0.15);
}

.oxygen-meta {
  display: flex;
  flex-direction: column;
  margin-left: 18rpx;
}

.oxygen-value {
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.1;
}

.oxygen-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--on-surface-variant);
}

.summary-pill,
.summary-caption {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.summary-pill {
  background: rgba(255, 255, 255, 0.92);
  color: var(--on-surface);
}

.summary-pill-primary {
  background: rgba(71, 166, 247, 0.14);
  color: var(--primary);
}

.summary-pill-success {
  background: rgba(91, 253, 140, 0.16);
  color: var(--tertiary);
}

.summary-stack {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.summary-caption {
  padding: 0;
  color: var(--on-surface-variant);
}

.forest-stage {
  position: relative;
  min-height: 980rpx;
  padding: 28rpx;
  overflow: hidden;
  border-radius: var(--radius-xl);
  background:
    radial-gradient(circle at top center, rgba(255, 255, 255, 0.38), transparent 24%),
    linear-gradient(180deg, rgba(71, 166, 247, 0.2), rgba(255, 255, 255, 0.72) 44%, rgba(91, 253, 140, 0.16) 100%),
    #eef7fb;
  box-shadow: var(--shadow-card);
}

.stage-glow {
  position: absolute;
  top: 72rpx;
  left: 50%;
  width: 360rpx;
  height: 220rpx;
  margin-left: -180rpx;
  background: rgba(255, 255, 255, 0.48);
  filter: blur(44rpx);
}

.grid-bg {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(0, 95, 155, 0.05) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(0, 95, 155, 0.05) 1rpx, transparent 1rpx);
  background-size: 52rpx 52rpx;
}

.stage-head {
  position: relative;
  z-index: 1;
  justify-content: space-between;
  align-items: flex-start;
}

.stage-chip {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  color: var(--primary);
  font-size: 22rpx;
  font-weight: 800;
  box-shadow: 0 12rpx 26rpx rgba(0, 95, 155, 0.08);
}

.energy-status {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
  padding: 16rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.6);
  color: var(--on-surface);
  font-size: 22rpx;
  font-weight: 700;
  backdrop-filter: blur(16px);
}

.vessel-container {
  position: relative;
  z-index: 1;
  width: 100%;
  height: calc(100vh - 660rpx);
  min-height: 620rpx;
  margin-top: 24rpx;
  border-radius: 56rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.38);
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.24), rgba(255, 255, 255, 0.1)),
    rgba(255, 255, 255, 0.16);
  backdrop-filter: blur(22px);
  overflow: hidden;
  box-shadow:
    inset 0 0 44rpx rgba(255, 255, 255, 0.22),
    0 24rpx 52rpx rgba(0, 95, 155, 0.08);
}

.vessel-glow,
.vessel-mist {
  position: absolute;
  pointer-events: none;
}

.vessel-glow {
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  filter: blur(30rpx);
}

.vessel-glow-top {
  top: 24rpx;
  left: 28rpx;
}

.vessel-glow-bottom {
  right: 32rpx;
  bottom: 22rpx;
}

.vessel-mist {
  inset: 0;
  background:
    radial-gradient(circle at 24% 22%, rgba(255, 255, 255, 0.26), transparent 22%),
    radial-gradient(circle at 76% 30%, rgba(255, 255, 255, 0.18), transparent 18%),
    radial-gradient(circle at 48% 72%, rgba(255, 255, 255, 0.14), transparent 18%);
}

.water-drop {
  position: absolute;
  border-radius: 50%;
  transition: all 0.25s cubic-bezier(0.175, 0.885, 0.320, 1.275);
  box-shadow:
    inset -12rpx -16rpx 28rpx rgba(8, 36, 64, 0.1),
    inset 10rpx 12rpx 18rpx rgba(255, 255, 255, 0.38),
    0 18rpx 26rpx rgba(0, 191, 255, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
}

.water-drop::after {
  content: '';
  position: absolute;
  inset: 8%;
  border-radius: 50%;
  border: 1rpx solid rgba(255, 255, 255, 0.28);
}

.water-drop.dragging {
  transform: scale(1.08);
  box-shadow:
    inset -12rpx -16rpx 28rpx rgba(8, 36, 64, 0.14),
    inset 10rpx 12rpx 18rpx rgba(255, 255, 255, 0.42),
    0 22rpx 36rpx rgba(0, 191, 255, 0.2);
}

.highlight {
  width: 32%;
  height: 32%;
  border-radius: 50%;
  position: absolute;
  top: 14%;
  left: 16%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.96), rgba(255, 255, 255, 0.12) 72%, transparent 100%);
}

.drop-core {
  width: 34%;
  height: 34%;
  position: absolute;
  right: 18%;
  bottom: 16%;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,0.18), rgba(255,255,255,0.02) 72%, transparent 100%);
}

@keyframes pop {
  0% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(1.22);
    opacity: 0.84;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

.merging {
  animation: pop 0.4s ease-out;
}

.vessel-empty {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 78%;
  transform: translate(-50%, -50%);
  padding: 30rpx 24rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.28);
  color: var(--on-surface);
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.6;
  text-align: center;
  backdrop-filter: blur(14px);
}

.achievement-overview,
.forest-log {
  padding-top: 36rpx;
}

.overview-head {
  justify-content: space-between;
  align-items: flex-start;
}

.forest-metrics {
  gap: 18rpx;
  margin-top: 24rpx;
}

.metric-block {
  flex: 1;
  padding: 20rpx 18rpx;
  border-radius: 28rpx;
  background: rgba(71, 166, 247, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.metric-value {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--primary);
  line-height: 1.2;
  text-align: center;
}

.metric-label {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: var(--on-surface-variant);
}

.forest-status-card {
  flex-direction: column;
  gap: 18rpx;
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 30rpx;
  background: rgba(243, 246, 248, 0.88);
}

.forest-row {
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.forest-row-label {
  font-size: 22rpx;
  color: var(--on-surface-variant);
}

.forest-row-value {
  flex: 1;
  text-align: right;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--on-surface);
}

.forest-row-value-compact {
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.5;
}

.bottom-space {
  height: 56rpx;
}

.stage-caption {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 24rpx;
  padding: 16rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(12, 53, 82, 0.72);
  color: #ffffff;
  font-size: 22rpx;
  line-height: 1.5;
  text-align: center;
}

.forest-action-btn {
  width: 100% !important;
  margin-top: 24rpx;
}

.summary-pill-primary,
.summary-pill-success,
.forest-action-btn {
  box-shadow: var(--shadow-card);
}
