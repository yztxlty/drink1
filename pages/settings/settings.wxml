<!-- pages/settings/settings.wxml -->
<scroll-view class="scrollarea" scroll-y>
  <view class="container settings-page">
    <view class="hero-card glass-card">
      <text class="hero-kicker">{{copy.heroKicker}}</text>
      <text class="hero-title">{{copy.heroTitle}}</text>
      <view class="hero-chip-row">
        <view class="hero-chip">目标 {{settings.dailyTarget}}ml</view>
        <view class="hero-chip">默认 {{settings.selectedCupAmount}}ml</view>
        <view class="hero-chip">本地保存</view>
      </view>
    </view>

    <view class="section-card glass-card">
      <view class="section-head">
        <text class="section-title">{{copy.dailyTargetTitle}}</text>
        <text class="section-value">{{settings.dailyTarget}}ml</text>
      </view>
      <slider
        min="800"
        max="3500"
        step="100"
        value="{{settings.dailyTarget}}"
        bindchanging="onGoalChanging"
        bindchange="onGoalChange"
        activeColor="#005f9b"
        backgroundColor="#dfe3e6"
        block-size="22"
      />
      <view class="range-row">
        <text>800ml</text>
        <text>3500ml</text>
      </view>
    </view>

    <view class="section-card glass-card">
      <quick-amount-manager
        quickAmounts="{{settings.quickAmounts}}"
        selectedAmount="{{settings.selectedCupAmount}}"
        title="{{copy.quickTitle}}"
        manageHint="{{copy.quickManageHint}}"
        deleteHint="{{copy.quickDeleteHint}}"
        sharedHint="{{copy.sharedHint}}"
        deleteModeTip="{{copy.quickDeleteModeTip}}"
        addLabel="{{copy.quickAddLabel}}"
        dialogTitle="{{copy.quickAddDialogTitle}}"
        dialogHint="{{copy.quickAddDialogHint}}"
        dialogTip="{{copy.quickAddDialogTip}}"
        confirmLabel="{{copy.quickAddConfirm}}"
        bindadd="handleQuickAmountAdd"
        bindselect="handleQuickAmountSelect"
        binddelete="handleQuickAmountDelete"
      />
    </view>

    <view class="section-card glass-card">
      <view class="section-head">
        <text class="section-title">{{copy.reminderTitle}}</text>
        <text class="section-note">按你的日程自动提醒</text>
      </view>
      <view class="reminder-list">
        <view class="reminder-item" wx:for="{{reminderItems}}" wx:key="key">
          <view class="reminder-copy">
            <text class="reminder-label">{{item.label}}</text>
            <text class="reminder-hint">{{item.hint}}</text>
          </view>
          <switch
            checked="{{settings.reminders[item.key]}}"
            data-key="{{item.key}}"
            bindchange="onToggleReminder"
            color="#005f9b"
          />
        </view>
      </view>
    </view>

    <view class="section-card glass-card">
      <text class="section-title">导出说明</text>
      <text class="section-body">{{copy.exportHint}}</text>
    </view>

    <view class="section-card glass-card data-management-entry" bindtap="goDataManagement">
      <view class="section-head data-management-head">
        <view>
          <text class="section-title">{{copy.dataManagementTitle}}</text>
          <text class="section-note">{{copy.dataManagementSubtitle}}</text>
        </view>
        <text class="data-management-action">{{copy.dataManagementAction}} ></text>
      </view>
    </view>

    <button class="primary-btn save-btn" bindtap="saveSettings">{{copy.saveLabel}}</button>
  </view>
</scroll-view>
